# Copy this file to `.env` and fill in your own values to enable Sepolia.
# NEVER commit a real .env file or a real private key.

# An Ethereum Sepolia JSON-RPC endpoint (e.g. from a public provider).
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# A funded Sepolia test account private key (test ETH only; no mainnet value).
PRIVATE_KEY=
